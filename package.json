{
  "name": "line-diff-action",
  "description": "A GitHub Action that generates a formatted diff between two commits",
  "version": "3.0.0",
  "author": "ILikePlayingGames",
  "license": "MIT",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/ILikePlayingGames/line-diff-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ILikePlayingGames/line-diff-action.git"
  },
  "bugs": {
    "url": "https://github.com/ILikePlayingGames/line-diff-action/issues"
  },
  "keywords": [
    "actions"
  ],
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.12.4",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.4.0",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.10",
    "typescript": "^5.9.3"
  }
}
